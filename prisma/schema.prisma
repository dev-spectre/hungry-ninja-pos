generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id           String          @id @default(uuid())
  name         String
  address      String?
  settings     Json?
  createdAt    DateTime        @default(now())
  users        User[]
  categories   Category[]
  products     Product[]
  inventory    InventoryItem[]
  transactions Transaction[]
  expenses     Expense[]
  dailyReports DailyReport[]
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String
  role         String   // "SUPER_ADMIN", "SHOP_MANAGER", "BILLING", "KITCHEN", "INVENTORY", "BRANCH_ADMIN"
  permissions  Json?    // Detailed RBAC permissions matrix
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String
  isDefault Boolean   @default(false)
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([name, branchId])
}

model Product {
  id             String              @id @default(uuid())
  name           String
  price          Float
  active         Boolean             @default(true)
  orderFrequency Int                 @default(0)
  categoryId     String
  category       Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  billItems      BillItemRecord[]
  ingredients    ProductIngredient[]
}

model InventoryItem {
  id                String              @id @default(uuid())
  name              String
  unit              String              // "pcs", "kg", "litre", "gm", "ml"
  currentStock      Float               @default(0)
  lowStockThreshold Float               @default(5)
  createdAt         DateTime            @default(now())
  branchId          String
  branch            Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredients       ProductIngredient[]
}

model ProductIngredient {
  id              String        @id @default(uuid())
  productId       String
  inventoryItemId String
  quantityNeeded  Float
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([productId, inventoryItemId])
}

model Transaction {
  id          String           @id @default(uuid())
  date        String           // YYYY-MM-DD
  timestamp   Float            // Unix ms
  total       Float
  paymentMode String           // "cash" | "upi" | "card"
  branchId    String
  branch      Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items       BillItemRecord[]
  createdAt   DateTime         @default(now())
}

model BillItemRecord {
  id            String      @id @default(uuid())
  productId     String
  productName   String
  price         Float
  quantity      Int
  subtotal      Float
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Expense {
  id        String   @id @default(uuid())
  title     String
  category  String   // raw_materials, salary, etc.
  amount    Float
  date      String   // YYYY-MM-DD
  notes     String?
  createdAt Float    // Unix ms
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id               String   @id @default(uuid())
  date             String   // YYYY-MM-DD
  archivedAt       Float    // Unix ms
  openingCash      Float
  totalSales       Float
  cashSales        Float
  upiSales         Float
  cardSales        Float
  totalItems       Int
  totalExpenses    Float
  netProfit        Float
  transactionCount Int
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([date, branchId])
}
